# Pyi-thon — AI Provider API Keys
# Copy this file to .env and fill in the key for your preferred provider.
# You only need ONE key — whichever provider you select in Settings.

# Claude (default) — https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — https://platform.openai.com
# VITE_OPENAI_API_KEY=sk-your-key-here

# Google Gemini — https://aistudio.google.com
# VITE_GEMINI_API_KEY=AIza-your-key-here

# Note: API keys can also be entered directly in the app's Settings panel.
# Offline mode (Pyodide) works without any API key.
